rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuth() { return request.auth != null; }
    function isOwner(uid) { return isAuth() && request.auth.uid == uid; }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.email == request.auth.token.email && !('premiumExpiry' in request.resource.data);
      allow update: if isOwner(userId) && request.resource.data.premiumExpiry == resource.data.premiumExpiry;
      allow delete: if false;
    }

    match /draft_affidavits/{docId} {
      allow read, write: if isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid && request.resource.data.name is string && request.resource.data.name.size() <= 100;
      allow delete: if isOwner(resource.data.userId);
    }

    match /affidavits/{docId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isOwner(resource.data.userId) && request.resource.data.userId == request.auth.uid && !('hash' in request.resource.data) && !('status' in request.resource.data);
      allow update, delete: if false;
    }

    match /rate_limits/{doc} { allow read, write: if false; }
    match /payment_logs/{doc} { allow read: if false; allow write: if false; }
    match /processed_payments/{doc} { allow read, write: if false; }
    match /verification_logs/{doc} { allow read, write: if false; }
    match /affidavit_logs/{doc} { allow read, write: if false; }

    match /{document=**} { allow read, write: if false; }
  }
}
