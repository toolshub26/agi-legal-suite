  "related_applications": [],

  "prefer_related_applications": false,

  "launch_handler": {
    "client_mode": "navigate-existing"
  },

  "edge_side_panel": {
    "preferred_width": 420
  },

  "handle_links": "preferred",

  "protocol_handlers": [

    {
      "protocol": "web+agi",
      "url": "./index.html?open=%s"
    }

  ],

  "file_handlers": [

    {
      "action": "./index.html",

      "accept": {

        "application/pdf": [
          ".pdf"
        ],

        "image/png": [
          ".png"
        ],

        "image/jpeg": [
          ".jpg",
          ".jpeg"
        ]

      }

    }

  ]

}
